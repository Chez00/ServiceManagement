{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "public/dist/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "public/dist/favicon.ico"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json|txt|xml))",
      "dest": "public/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/dist/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}